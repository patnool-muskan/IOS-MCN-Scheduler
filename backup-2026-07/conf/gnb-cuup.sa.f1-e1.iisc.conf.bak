Active_gNBs = ( "IISC");
# Asn1_verbosity, choice in: none, info, annoying
Asn1_verbosity = "none";
sa = 1;

gNBs =
(
 {
    ////////// Identification parameters:
    gNB_ID = 0xe06;
    gNB_CU_UP_ID = 0xe06;

    gNB_name  =  "IISC";

    // Tracking area code, 0x0000 and 0xfffe are reserved values
    tracking_area_code  = 1;
    plmn_list = ({ mcc = 001; 
                    mnc = 01; 
                    mnc_length = 2; 
                    snssaiList = ({ sst = 1; 
                                    sd = 0x000000;
                                  }); 
                  }); # PLMN identity used to connect with the CORE.


    tr_s_preference = "f1";

    local_s_if_name = "lo";
    local_s_address = "127.0.0.5"; # IPv4 address of CU-UP.
    remote_s_address = "127.0.0.3"; # IPv4 address of DU.
    local_s_portc   = 501;
    local_s_portd   = 2153;
    remote_s_portc  = 500;
    remote_s_portd  = 2153;

    # ------- SCTP definitions
    SCTP :
    {
        # Number of streams to use in input/output
        SCTP_INSTREAMS  = 2;
        SCTP_OUTSTREAMS = 2;
    };

    E1_INTERFACE =
    (
      {
        type = "up";
        ipv4_cucp =  "127.0.0.4"; # Address of the CU-CP entity
        ipv4_cuup =  "127.0.0.5"; # Address of the CU-UP entity
      }
    )

    NETWORK_INTERFACES :
    {
        GNB_INTERFACE_NAME_FOR_NG_AMF            = "enp1s0f0"; # Network interface name used to connect with AMF.
        GNB_IPV4_ADDRESS_FOR_NG_AMF              = "10.33.42.244" # Address of the Network interface used to connect with the AMF.
        GNB_INTERFACE_NAME_FOR_NGU               = "enp1s0f0"; # Network interface name used to connect with UPF.
        GNB_IPV4_ADDRESS_FOR_NGU                 = "10.33.42.244"; # IPv4 address to connect UPF.
        GNB_PORT_FOR_S1U                         = 2152; # Spec 2152
    };
  }
);

log_config : {
  global_log_level = "info";
  pdcp_log_level   = "info";
  f1ap_log_level   = "info";
  ngap_log_level   = "info";
};
