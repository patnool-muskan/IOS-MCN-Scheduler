<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="MeasDataCollection.xsl"?>
<measCollecFile xmlns="http://www.3gpp.org/ftp/specs/archive/32_series/32.435#measCollec"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.3gpp.org/ftp/specs/archive/32_series/32.435#measCollec http://www.3gpp.org/ftp/specs/archive/32_series/32.435#measCollec">
	<fileHeader fileFormatVersion="32.435 V7.0" vendorName="@vendor@" dnPrefix="DC=openairinterface.org">
		<fileSender localDn="ManagedElement=@node-id@" elementType="GNBDU"/>
		<measCollec beginTime="@start-time@"/>
	</fileHeader>
	<measData>
		<managedElement localDn="ManagedElement=@node-id@" userLabel=""/>
		<measInfo>
			<job jobId="1"/>
			<granPeriod duration="PT@log-period@S" endTime="@end-time@"/>
			<repPeriod duration="P1D"/>
			<measType p="1">DRB.MeanActiveUeDl</measType>
			<measType p="2">DRB.MaxActiveUeDl</measType>
			<measType p="3">DRB.MeanActiveUeUl</measType>
			<measType p="4">DRB.MaxActiveUeUl</measType>
			<measType p="5">RRU.PrbTotDl</measType>
			<measType p="6">DRB.UEThpDl</measType>
			<measType p="7">DRB.UEThpUl</measType>
			<measType p="8">RRU.PrbTotUl</measType>
			<measType p="9">RRU.PrbDl</measType>
			<measType p="10">RRU.PrbUl</measType>
			<measType p="11">RRU.DlUlTbs</measType>
			<measType p="12">RRU.DlErrTbs</measType>
			<measType p="13">RRU.UlErrTbs</measType>
			<measType p="14">RRU.UlPdcpSdu</measType>
			<measType p="15">RRU.DlPdcpSdu</measType>
			<measType p="16">RU.TotalRxGoodPktCnt</measType>
			<measType p="17">RU.TotalRxBitRate</measType>
			<measType p="18">RU.OranRxOnTime</measType>
			<measType p="19">RU.OranRxEarly</measType>
			<measType p="20">RU.OranRxLate</measType>
			<measType p="21">RU.OranRxCorrupt</measType>
			<measType p="22">RU.OranRxTotal</measType>
			<measType p="23">RU.OranRxTotalC</measType>
			<measType p="24">RU.OranRxOnTimeC</measType>
			<measType p="25">RU.OranRxEarlyC</measType>
			<measType p="26">RU.OranRxLateC</measType>
			<measType p="27">RU.OranRxErrorDrop</measType>
			<measType p="28">RU.OranTxTotal</measType>
			<measType p="29">RU.OranTxTotalC</measType>
			<measValue measObjLdn="DuFunction=@du-id@,CellId=@cell-id@">
				<r p="1">@mean-active-ue@</r>
				<r p="2">@max-active-ue@</r>
				<r p="3">@mean-active-ue@</r>
				<r p="4">@max-active-ue@</r>
				<r p="5">@load-avg@</r>
				<r p="6">@ue-thp-dl@</r>
				<r p="7">@ue-thp-ul@</r>
				<r p="8">@tot-ul-prbs@</r>
				<r p="9">@dl-prbs@</r>
				<r p="10">@ul-prbs@</r>
				<r p="11">@dl-ul-tbs@</r>
				<r p="12">@dl-tbs-err@</r>
				<r p="13">@ul-tbs-err@</r>
				<r p="14">@ul-pdcp-sdu@</r>
				<r p="15">@dl-pdcp-sdu@</r>
				<r p="16">@total-rx-good-pkt-cnt@</r>
				<r p="17">@total-rx-bit-rate@</r>
				<r p="18">@oran-rx-on-time@</r>
				<r p="19">@oran-rx-early@</r>
				<r p="20">@oran-rx-late@</r>
				<r p="21">@oran-rx-corrupt@</r>
				<r p="22">@oran-rx-total@</r>
				<r p="23">@oran-rx-total-c@</r>
				<r p="24">@oran-rx-on-time-c@</r>
				<r p="25">@oran-rx-early-c@</r>
				<r p="26">@oran-rx-late-c@</r>
				<r p="27">@oran-rx-error-drop@</r>
				<r p="28">@oran-tx-total@</r>
				<r p="29">@oran-tx-total-c@</r>
			</measValue>
		</measInfo>
	</measData>
	<fileFooter>
		<measCollec endTime="@end-time@"/>
	</fileFooter>
</measCollecFile>
