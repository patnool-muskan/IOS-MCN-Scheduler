<testCaseList>
        <htmlTabRef>rfsim-5gnr-e1</htmlTabRef>
        <htmlTabName>CUCP-CUUP-DU E1+F1 split</htmlTabName>
        <htmlTabIcon>wrench</htmlTabIcon>
        <TestCaseRequestedList>
 000001
 000002
 000003
 000004
 000005
        </TestCaseRequestedList>
        <TestCaseExclusionList></TestCaseExclusionList>

        <testCase id="000001">
                <class>Deploy_Object</class>
                <desc>Deploy OAI 5G RAN RF sim SA (1 CU-CP, 1 CU-UP, 1 DU)</desc>
                <yaml_path>cicd/5g_sa_rfsim/docker-compose.yaml</yaml_path>
                <services>ios-mcn-cucp ios-mcn-cuup ios-mcn-du</services>
                <eNB_instance>0</eNB_instance>
                <eNB_serverId>0</eNB_serverId>
        </testCase>

        <testCase id="000002">
                <class>Deploy_Object</class>
                <desc>Deploy OAI 5G NR-UE RF sim SA</desc>
                <yaml_path>cicd/5g_sa_rfsim/docker-compose.yaml</yaml_path>
                <services>ios-mcn-nr-ue</services>
                <eNB_instance>0</eNB_instance>
                <eNB_serverId>0</eNB_serverId>
        </testCase>

        <testCase id="000003">
                <class>Attach_UE</class>
                <desc>Attach OAI UE (Wait for IP)</desc>
                <id>ios-mcn-nr-ue</id>
                <nodes>cacofonix cacofonix cacofonix</nodes>
        </testCase>

        <testCase id="000004">
                <class>Ping</class>
                <desc>Ping ext-dn from all NR-UEs</desc>
                <id>ios-mcn-nr-ue</id>
                <ping_args>-c 20 -i0.25</ping_args>
                <ping_packetloss_threshold>5</ping_packetloss_threshold>
        </testCase>

        <testCase id="000005">
                <class>Undeploy_Object</class>
                <always_exec>true</always_exec>
                <desc>Undeploy all OAI 5G stack</desc>
                <yaml_path>cicd/5g_sa_rfsim/docker-compose.yaml</yaml_path>
                <d_retx_th>1,0,0,0</d_retx_th>
                <u_retx_th>1,0,0,0</u_retx_th>
                <eNB_instance>0</eNB_instance>
                <eNB_serverId>0</eNB_serverId>
        </testCase>

</testCaseList>
